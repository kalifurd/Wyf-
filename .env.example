# WYF* Engine Configuration
# Copy this file to .env and fill in your actual values
# NEVER commit the .env file to version control

# ============================================================================
# AI Provider Selection
# ============================================================================
# Choose your AI provider: "ollama" (local) or "openrouter" (cloud)
# Recommended: ollama (no API keys required, fully local)
AI_PROVIDER=ollama

# ============================================================================
# Ollama Configuration (for local inference - NO API KEYS REQUIRED)
# ============================================================================
# Base URL where Ollama is running
OLLAMA_BASE_URL=http://localhost:11434

# Model to use with Ollama
# RECOMMENDED MODELS (no external API key):
# - phi3: 3.8B lightweight, fast, good for realtime dialogue
# - llava-phi3: Vision + language, can analyze images
# - neural-chat: Balanced, good for romance narratives
# - mistral: Powerful, ~7B parameters
#
# Install models with: ollama pull <model-name>
# For narrative/Caretaker: phi3 (lightweight) or neural-chat (better quality)
# For vision analysis (sprite biometrics): llava-phi3
OLLAMA_MODEL=phi3

# For vision-based sprite analysis (detect player emotion, engagement)
# Optional: set to "" to disable
OLLAMA_VISION_MODEL=llava-phi3

# Ollama Pi CLI (for edge devices / Raspberry Pi)
# Set to true if running on resource-constrained hardware
OLLAMA_PI_MODE=false

# ============================================================================
# Ollama Model Installation Quick Reference
# ============================================================================
# NO API KEY NEEDED - All models run 100% locally
#
# Text Generation (Narrative):
#   ollama pull phi3              # 3.8B, fastest, good enough for Caretaker
#   ollama pull neural-chat       # Better quality, slower
#   ollama pull mistral           # 7B, powerful, slower on weak hardware
#
# Vision + Language (Sprite Biometrics):
#   ollama pull llava-phi3        # Vision-capable, lightweight
#
# Run Ollama server:
#   ollama serve                  # Starts at localhost:11434
#
# Test models:
#   ollama run phi3 "Say hello"
#   ollama run llava-phi3 "Describe this image: [path]"
#

# ============================================================================
# OpenRouter Configuration (for cloud-based inference - OPTIONAL)
# ============================================================================
# Your OpenRouter API key (get from https://openrouter.ai)
# ONLY required if AI_PROVIDER=openrouter
# Leave empty to use local Ollama instead
OPENROUTER_API_KEY=

# ============================================================================
# FastAPI Configuration
# ============================================================================
# Server host (default: 127.0.0.1 for localhost only)
FASTAPI_HOST=127.0.0.1

# Server port (default: 8000)
FASTAPI_PORT=8000

# Enable auto-reload in development (default: true)
FASTAPI_RELOAD=true

# Log level (debug, info, warning, error, critical)
FASTAPI_LOG_LEVEL=info

# ============================================================================
# Audio/TTS Configuration (Piper - Text-to-Speech)
# ============================================================================
# Enable text-to-speech narration (default: false)
PIPER_ENABLED=false

# Path to Piper executable
# Install: https://github.com/rhasspy/piper
PIPER_PATH=/usr/local/bin/piper

# Piper voice model (e.g., "en_US-lessac-medium")
# Download models from: https://huggingface.co/rhasspy/piper-voices
PIPER_VOICE=en_US-lessac-medium

# Audio output directory for generated narration
PIPER_OUTPUT_DIR=./audio

# ============================================================================
# Biometric / Sprite Engine Configuration
# ============================================================================
# WebSocket port for real-time biometric streaming (eye tracking, haptics)
BIOMETRIC_WS_PORT=8001

# Enable sprite biometric awareness (eye tracking, typing detection, etc.)
BIOMETRIC_ENABLED=true

# Eye tracking provider: "webgazer" (browser-based, free) or "tobii" (hardware)
EYE_TRACKING_PROVIDER=webgazer

# Haptic feedback enabled (phone vibration, haptic device)
HAPTIC_ENABLED=true

# ============================================================================
# Kiwix/IIAB Configuration (Offline Content Server)
# ============================================================================
# Enable Kiwix offline content server (default: false)
KIWIX_ENABLED=false

# Base URL of Kiwix server
KIWIX_BASE_URL=http://localhost:8080

# Path to Kiwix data directory
KIWIX_DATA_DIR=./kiwix-data

# ============================================================================
# Hermes Agent Configuration (@NousResearch/hermes-agent)
# ============================================================================
# Enable Hermes agent framework (default: false)
# Hermes makes intelligent narrative decisions and orchestrates story flow
HERMES_ENABLED=false

# Hermes agent service URL (if running separately)
HERMES_API_URL=http://localhost:8001

# Hermes model to use (if running locally)
HERMES_MODEL=hermes-2-pro-7b

# ============================================================================
# Output Formats
# ============================================================================
# Enable audio output (requires Piper)
OUTPUT_AUDIO=false

# Enable video output generation (future feature)
OUTPUT_VIDEO=false

# Output directory for all generated media
OUTPUT_DIR=./output

# ============================================================================
# Asset Pipeline Configuration
# ============================================================================
# Directory to watch for new Tripo3D.ai exports
ASSET_WATCH_DIR=./Downloads/TripoExports

# Target directory for character assets
ASSET_TARGET_DIR=./assets/characters

# Godot project directory (for auto-reimport)
GODOT_PROJECT_DIR=./godot

# ============================================================================
# Story Configuration
# ============================================================================
# Default storyline base prompt
STORY_BASE_PROMPT=The Lost Heirloom

# Default story setting
STORY_SETTING=Victorian London, 1888

# Enable three-path storyline system (A/B/C)
STORYLINE_SYSTEM_ENABLED=true
